local function getESPColor()
    local map = {Branco=Color3.new(1,1,1),Vermelho=Color3.fromRGB(255,0,0),Verde=Color3.fromRGB(0,255,0),
        Azul=Color3.fromRGB(0,170,255),Amarelo=Color3.fromRGB(255,255,0),Rosa=Color3.fromRGB(255,105,180),Roxo=Color3.fromRGB(128,0,128)}
    if espColor=="RGB" then return Color3.fromHSV((tick()%5)/5,1,1) end
    return map[espColor] or Color3.new(1,1,1)
end

local function makeESP(p)
    if p==localPlayer then return end
    local c = p.Character; if not c then return end
    local head = c:FindFirstChild("Head"); if not head then return end
    if espBillboards[p] then espBillboards[p]:Destroy() end
    local bb = Instance.new("BillboardGui")
    bb.Parent=head; bb.Adornee=head; bb.Size=UDim2.new(0,200,0,50)
    bb.StudsOffset=Vector3.new(0,3,0); bb.AlwaysOnTop=true
    local tl = Instance.new("TextLabel",bb)
    tl.Size=UDim2.new(1,0,1,0); tl.BackgroundTransparency=1
    tl.Font=Enum.Font.GothamBold; tl.TextSize=13; tl.TextStrokeTransparency=0.4
    tl.Text=p.Name.." ["..p.AccountAge.."d]"; tl.TextColor3=getESPColor()
    espBillboards[p]=bb
end

Tab2:AddToggle({Name="ESP Players",Default=false,Callback=function(v)
    espEnabled=v
    if v then
        for _,p in pairs(Players:GetPlayers()) do makeESP(p) end
        table.insert(espConns, RunService.Heartbeat:Connect(function()
            for _,p in pairs(Players:GetPlayers()) do
                if espEnabled then makeESP(p) end
                local bb = espBillboards[p]
                if bb and bb:FindFirstChild("TextLabel") then bb.TextLabel.TextColor3=getESPColor() end
            end
        end))
    else
        for _,bb in pairs(espBillboards) do if bb then bb:Destroy() end end
        espBillboards={}
        for _,c in pairs(espConns) do c:Disconnect() end
        espConns={}
    end
end})

