-- Bola girando na pessoa - parece que eh bom no fut mas eh troll
local bolaGirando = false
local bolaConn = nil

Tab9:AddToggle({
    Name = "Bola Girando no Player",
    Description = "A bola fica grudada na pessoa parecendo que voce joga bem",
    Default = false,
    Callback = function(v)
        bolaGirando = v
        if v then
            if not selectedPlayerName then
                Notify("Erro","Selecione um jogador!",3)
                bolaGirando = false
                return
            end

            -- Equipa a bola
            local backpack = localPlayer:WaitForChild("Backpack")
            if not backpack:FindFirstChild("SoccerBall") then
                pcall(function()
                    ReplicatedStorage.RE:FindFirstChild("1Too1l"):InvokeServer("PickingTools","SoccerBall")
                end)
                local t = 0
                repeat task.wait(0.1); t+=0.1 until backpack:FindFirstChild("SoccerBall") or t >= 3
            end
            local bola = backpack:FindFirstChild("SoccerBall")
            if bola then bola.Parent = localPlayer.Character end
            task.wait(0.3)

            -- Pega a bola no workspace
            pcall(function()
                ReplicatedStorage.RE["1Clea1rTool1s"]:FireServer("PlayerWantsToDeleteTool","SoccerBall")
            end)
            task.wait(0.3)

            local workspaceCom = workspace:FindFirstChild("WorkspaceCom")
            local soccerBalls = workspaceCom and workspaceCom:FindFirstChild("001_SoccerBalls")
            if not soccerBalls then
                Notify("Erro","SoccerBalls nao encontrado.",3)
                bolaGirando = false
                return
            end
            local ball = soccerBalls:FindFirstChild("Soccer"..localPlayer.Name)
            if not ball then
                Notify("Erro","Bola nao encontrada.",3)
                bolaGirando = false
                return
            end

            ball.Anchored = false
            ball.CanCollide = false
            ball.Massless = true

            local angle = 0
            local bounce = 0
            local radius = 3

            bolaConn = RunService.Heartbeat:Connect(function(dt)
                if not bolaGirando then
                    if bolaConn then bolaConn:Disconnect(); bolaConn = nil end
                    return
                end
                local target = Players:FindFirstChild(selectedPlayerName)
                if not target or not target.Character then return end
                local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
                if not tHRP then return end

                -- Gira em orbita ao redor da pessoa
                angle = angle + dt * 4
                bounce = bounce + dt * 6

                -- Posicao em orbita com quique
                local orbitX = math.cos(angle) * radius
                local orbitZ = math.sin(angle) * radius
                local bouncY = math.abs(math.sin(bounce)) * 2 -- quica no chao

