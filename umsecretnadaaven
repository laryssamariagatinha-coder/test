        -- Teleporta para spawn do bus
        pcall(function()
            myHRP.Anchored = true
            myHRP.CFrame = CFrame.new(1181.83,76.08,-1158.83)
            task.wait(0.2)
            myHRP.Velocity = Vector3.zero
            myHRP.RotVelocity = Vector3.zero
            myHRP.Anchored = false
            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        end)
        task.wait(0.5)

        -- Pega bus
        pcall(function()
            ReplicatedStorage.RE["1Ca1r"]:FireServer("DeleteAllVehicles")
        end)
        task.wait(0.2)
        pcall(function()
            ReplicatedStorage.RE["1Ca1r"]:FireServer("PickingCar","SchoolBus")
        end)
        task.wait(1)

        local vehiclesFolder = workspace:FindFirstChild("Vehicles")
        if not vehiclesFolder then Notify("Erro","Vehicles nao encontrado.",3) return end
        local bus = vehiclesFolder:FindFirstChild(localPlayer.Name.."Car")
        if not bus then Notify("Erro","Bus nao spawnado.",3) return end

        -- Senta no bus
        pcall(function()
            myHRP.Anchored = true
            myHRP.CFrame = CFrame.new(1171.15,79.45,-1166.2)
            task.wait(0.2)
            myHRP.Velocity = Vector3.zero
            myHRP.RotVelocity = Vector3.zero
            myHRP.Anchored = false
            humanoid:ChangeState(Enum.HumanoidStateType.Seated)
        end)

        local sitStart = tick()
        repeat task.wait() until humanoid.Sit or tick()-sitStart > 10
        if not humanoid.Sit then Notify("Erro","Nao conseguiu sentar no bus.",3) return end

        -- Noclip do bus
        for _,part in ipairs(bus:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end

        local lynixBusRunning = true
        local lynixConn = nil
        local startTime = tick()
        local updateInterval = 0.03

        lynixConn = RunService.Heartbeat:Connect(function()
            if not lynixBusRunning then return end
            local tChar = targetPlayer.Character
            local tHRP = tChar and tChar:FindFirstChild("HumanoidRootPart")
            local tHum = tChar and tChar:FindFirstChildOfClass("Humanoid")
            if not tHRP or not tHum then return end

            -- Move bus com rotacao agressiva em volta do alvo
            local offset = Vector3.new(math.random(-5,5),0,math.random(-5,5))
            pcall(function()
                bus:PivotTo(
                    CFrame.new(tHRP.Position + offset) *
                    CFrame.Angles(
                        math.rad(workspace.DistributedGameTime * 15000),
                        math.rad(workspace.DistributedGameTime * 18000),
                        math.rad(workspace.DistributedGameTime * 20000)
                    )
                )
            end)

            -- Verifica se alvo sentou
            local playerSeated = false
            for _,seat in ipairs(bus:GetDescendants()) do
                if (seat:IsA("Seat") or seat:IsA("VehicleSeat")) and seat.Name~="VehicleSeat" then
                    if seat.Occupant == tHum then playerSeated=true break end
                end
            end

            if playerSeated or tick()-startTime > 8 then
                lynixBusRunning = false
                if lynixConn then lynixConn:Disconnect() end

                -- Joga bus no void
                pcall(function() bus:PivotTo(CFrame.new(0,-1000,0)) end)
                task.wait(0.3)

                pcall(function()
                    ReplicatedStorage.RE["1Ca1r"]:FireServer("DeleteAllVehicles")
                end)

                -- Volta player para posicao original
                task.wait(0.3)
                pcall(function()
                    myHRP.Anchored = true
                    myHRP.CFrame = CFrame.new(savedPos + Vector3.new(0,5,0))
                    task.wait(0.2)
                    myHRP.Velocity = Vector3.zero
                    myHRP.RotVelocity = Vector3.zero
                    myHRP.Anchored = false
                    humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                end)
                for _,part in ipairs(character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = true
                        part.Velocity = Vector3.zero
                        part.RotVelocity = Vector3.zero
                    end
                end
                humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated,true)
                Notify("Kill Bus Lynix","Kill executado!",3)
            end
        end)

        -- Timeout de seguranca
        task.spawn(function()
            task.wait(15)
            if lynixBusRunning then
                lynixBusRunning = false
                if lynixConn then lynixConn:Disconnect() end
                pcall(function() ReplicatedStorage.RE["1Ca1r"]:FireServer("DeleteAllVehicles") end)
                Notify("Bus","Timeout - bus deletado.",3)
            end
        end)

        Notify("Kill Bus Lynix","Bus ativado! Aguarde...",4)
    end
})

