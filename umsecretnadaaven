        task.wait(0.01)
        ReplicatedStorage.RE:FindFirstChild("1Too1l"):InvokeServer("PickingTools","Couch")
        task.wait(0.2)
        root.CFrame = CFrame.new(originalPos)
    end)
    Notify("Kill Couch","Kill ativado! 🛋️",3)
end

